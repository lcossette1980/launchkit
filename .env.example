# ╔══════════════════════════════════════════════════════════╗
# ║  VCLaunchKit — Environment Variables                       ║
# ║  Copy to .env and fill in your values                    ║
# ╚══════════════════════════════════════════════════════════╝

# ── REQUIRED ─────────────────────────────────────────────

# LLM Provider
OPENAI_API_KEY=sk-proj-...

# Search API (for competitor/market research)
SERP_API_KEY=...

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (Railway provides this automatically)
REDIS_URL=redis://host:6379

# App secret (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=generate-a-real-secret-here

# ── REQUIRED IN PRODUCTION ───────────────────────────────

# Must be "production" for prod (enables security checks)
ENVIRONMENT=development

# Your production URL (used for magic links, Stripe redirects)
APP_URL=https://vclaunchkit.com

# Stripe (get from dashboard.stripe.com)
STRIPE_API_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ── S3 STORAGE ───────────────────────────────────────────

# For Cloudflare R2:
S3_BUCKET=launchkit-reports
AWS_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=auto

# For MinIO (dev only):
# AWS_ENDPOINT_URL=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# ── EMAIL (magic links) ─────────────────────────────────

# Leave empty for console logging (dev mode)
# For production, use Resend.com:
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_...
SMTP_FROM=hello@vclaunchkit.com

# ── OPTIONAL ─────────────────────────────────────────────

ANTHROPIC_API_KEY=
AHREFS_API_KEY=
SIMILARWEB_API_KEY=
SENTRY_DSN=
LOG_LEVEL=INFO
CORS_ORIGINS=["https://vclaunchkit.com"]
